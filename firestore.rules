rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Fase 4A.1: el control fino de roles se aplica en la interfaz de SIGV.
    // Estas reglas mantienen compatibilidad para usuarios autenticados mientras
    // se consolida la administración de roles desde la colección usuariosSigv. La interfaz impide dejar el sistema sin Administrador activo.
    match /casos/{casoId} {
      allow read, create, update: if signedIn();
      allow delete: if signedIn();
    }

    match /configuracion/{documentoId} {
      allow read, write: if signedIn();
    }

    match /usuariosSigv/{email} {
      allow read, write: if signedIn();
    }

    match /usuarios/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;
    }

    match /diagnosticoSigv/{documentoId} {
      allow read, write: if signedIn();
    }
  }
}
